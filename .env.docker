# Configuración de Docker para PequeLectores
# Copiar este archivo como .env antes de ejecutar docker compose

# PostgreSQL
DB_USER=pequena_users
DB_PASSWORD=pequena_secret
DB_NAME=pequena_lectores
DB_PORT=5433

# Backend
SECRET_KEY=dev-secret-key-please-change-in-production

# Puertos (estos mapean a localhost)
BACKEND_PORT=8000
FRONTEND_PORT=5173